{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "URUS",
  "scopeName": "source.urus",
  "fileTypes": ["urus"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#fstrings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#functions" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.urus",
          "match": "//.*$"
        },
        {
          "name": "comment.block.urus",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.urus",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.urus",
          "match": "\\\\."
        }
      ]
    },
    "fstrings": {
      "name": "string.interpolated.urus",
      "begin": "f\"",
      "end": "\"",
      "patterns": [
        {
          "name": "meta.interpolation.urus",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            { "include": "#keywords" },
            { "include": "#builtins" },
            { "include": "#numbers" },
            { "include": "#operators" }
          ]
        },
        {
          "name": "constant.character.escape.urus",
          "match": "\\\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.urus",
          "match": "\\b(if|else|while|for|in|return|break|continue|match)\\b"
        },
        {
          "name": "keyword.declaration.urus",
          "match": "\\b(fn|let|mut|struct|enum|import)\\b"
        },
        {
          "name": "keyword.other.urus",
          "match": "\\b(Ok|Err)\\b"
        }
      ]
    },
    "types": {
      "name": "storage.type.urus",
      "match": "\\b(int|float|bool|str|void|Result)\\b"
    },
    "constants": {
      "name": "constant.language.urus",
      "match": "\\b(true|false)\\b"
    },
    "builtins": {
      "name": "support.function.builtin.urus",
      "match": "\\b(print|input|read_file|write_file|append_file|len|push|pop|str_len|str_upper|str_lower|str_trim|str_contains|str_find|str_slice|str_replace|str_starts_with|str_ends_with|str_split|char_at|to_str|to_int|to_float|abs|fabs|sqrt|pow|min|max|fmin|fmax|is_ok|is_err|unwrap|unwrap_err|exit|assert)\\b"
    },
    "functions": {
      "name": "entity.name.function.urus",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.urus",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.urus",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.urus",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.urus",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.urus",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.urus",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.range.urus",
          "match": "\\.\\.(=?)"
        },
        {
          "name": "keyword.operator.arrow.urus",
          "match": "=>"
        }
      ]
    }
  }
}
